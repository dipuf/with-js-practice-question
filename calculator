<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document</title>
  <link rel="stylesheet" href="index.css">
</head>
<body>
  <div class="container">
    <h1>Simple Calculator</h1>
    <label>Enter First Number</label>
    <input type = "number" id = "first" name = "first">
    <label>Enter Second Number</label>
    <input type = "number" id = "second" name="second">
    <label>Choose an operator</label>
    <select id = "operator">
      <option value="+">+</option>
      <option value="-">-</option>
      <option value="/">/</option>
      <option value="*">*</option>
    </select>
    <div class="btn">
      <button>Calculate</button>
      <button>Reset</button>
    </div>
    <h2 id = "result">Result:</h2>
  </div>
  <script src="inde.js"></script>
</body>
</html>

let btn = document.querySelector(".btn").children[0];

btn.addEventListener("click", function () {
  let a = Number(document.querySelector("#first").value);
  let b = Number(document.querySelector("#second").value);
  let op = document.querySelector("#operator").value;
  let res;

  switch (op) { 
    case '+':
      res = a + b;
      break;
    case '-':
      res = a - b;
      break;
    case '*':
      res = a * b;
      break;
    case '/':
      res = b !== 0 ? a / b : "Cannot divide by 0";
      break;
    default:
      res = "Invalid input";
  }

  document.querySelector("#result").innerText = "Result: " + res;
});

body{
    background-color: grey;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    
}

.container{
    max-width: 100vw;
    min-height: 60vh;
    background-color: white;
    display: flex;
    flex-direction: column;
    border: 5px solid skyblue;
    border-radius: 3px;
}
.container>h1{
    text-align: center;
    margin-left: 4px;
    margin-right: 4px;

}
.container input,.container>select{
 height: 25px;
 margin:8px 20px;
}
.container label{
    margin-left: 20px;
}
.btn{
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-top: 10px;
}
.btn button{
    background-color: rgba(0, 128, 0, 0.653);
    height: 30px;
    width: 80px;
    border: none;
    border-radius: 5px;
    color: white;
}
.container>h2{
    text-align: center;
}
@media screen and (max-width:400px) {
    *{
        flex-wrap: wrap;
    }
}
