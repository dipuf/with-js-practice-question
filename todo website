body{
    display: flex;  
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    background-color: rgba(78, 76, 76, 0.250);
}

*{
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/* CONTAINER */
.container{
    background-color: white;
    width: 100%;
    max-width: 400px;   /* important */
    border: 8px solid rgb(86, 211, 86);
    border-radius: 10px;
    padding-bottom: 20px;
}

/* TITLE */
.container>h1{
    margin: 15px 10%;
    padding: 10px;
    text-align: center;
}

/* ADD TASK */
.addTask{
    display: flex;
    width: 80%;    
    margin: 0 auto;
}

.addTask>button{
    width: 100%;
    height: 40px;
    display: flex;
    align-items: center;
    padding: 10px;
    background-color: rgba(200,200,200,0.8);   
    border-radius: 10px;
    border: none;
    position: relative;
}

.addTask>button img{
    height: 22px;
    position: absolute;
    right: 10px;
    bottom: 9px;
}

/* TASK TITLE */
h2{
    text-align: center;
    margin: 15px 0;
}   

/* COMMON CARD STYLE */
.study, .workout{
    width: 80%;
    margin: 0 auto 20px auto;
    background-color: rgba(200,200,200,0.8);  
    border: 4px solid #86ce1afc;
    border-radius: 6px;
    padding: 10px;
}

/* INNER TEXT */
.study .inner,
.workout .inside{
    margin-left: 5px;
    line-height: 28px;
}

/* ICONS */
.images, .images2{
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
}

.images img,
.images2 img{
    height: 25px;
    margin: 10px;
}

/* 📱 SMALL DEVICES */
@media screen and (max-width: 600px) {
    .container{
        max-width: 95%;
    }

    .addTask{
        width: 90%;
    }

    .study, .workout{
        width: 90%;
    }

    .addTask>button{
        font-size: 14px;
    }
}

/* 📱 VERY SMALL (phones) */
@media screen and (max-width: 400px) {
    .addTask>button img{
        right: 5px;
    }

    .images img,
    .images2 img{
        height: 22px;
        margin: 8px;
    }
}       



let addItem = document.querySelector(".add img");
let container = document.querySelector(".container");
addItem.addEventListener("click", function() {
  if (container.querySelector('.workout')){
    alert("please remove workout card");
  }
  else{
    let work = document.createElement("div");
    work.className = "workout"
    work.innerHTML =
    `<div class="inside">  
        <h3>Workout</h3>
        <date>2019-10-31</date>
        <p>Leg Day</p>
        <div class="images2">
          <img src = "https://ico.hugeicons.com/file-edit-stroke-rounded@2x.webp?v=1.0.0" alt = "no img found">
          <img class="wrk-delete" src = "https://ico.hugeicons.com/delete-02-stroke-rounded@2x.webp?v=1.0.0" alt = "no second image found">
        </div>
      </div>`
    container.append(work)
  }
});

container.addEventListener("click", function(event) {
  if (event.target.matches(".wrk-delete")) {
    let workoutCard = event.target.closest(".workout");
    if (workoutCard) {
      workoutCard.remove();
      alert("deleted");
    }
  }
});

