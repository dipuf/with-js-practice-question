        <div class="images">
          <img src = "https://ico.hugeicons.com/file-edit-stroke-rounded@2x.webp?v=1.0.0" alt = "no img found">
          <img src = "https://ico.hugeicons.com/delete-02-stroke-rounded@2x.webp?v=1.0.0" alt = "no second image found">
        </div>
      </div>
    </div>
    <!-- break -->
      <div class="workout">
      <div class="inside">  
        <h3>Workout</h3>
        <date>2019-10-31</date>
        <p>Leg Day</p>
        <div class="images2">
          <img src = "https://ico.hugeicons.com/file-edit-stroke-rounded@2x.webp?v=1.0.0" alt = "no img found">
          <img class="wrk-delete" src = "https://ico.hugeicons.com/delete-02-stroke-rounded@2x.webp?v=1.0.0" alt = "no second image found">
        </div>
      </div>  
    </div>
    <!-- break -->
